# ===== Failure Museum backend config =====
# Copy this file to .env and fill in your online API key.
# If no key is set, the app falls back to local hashing embeddings + rule-based
# generation, so the UI still demos (with reduced semantic quality).

# ---- Chat model: failure-card extraction, requirement normalization, risk report ----
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=0

# ---- Embedding model: vectorization + semantic search ----
# Falls back to LLM_API_KEY / LLM_BASE_URL when empty.
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=text-embedding-3-small
EMBED_TIMEOUT_SECONDS=8
EMBED_MAX_RETRIES=0

# ---- Local storage ----
STORAGE_FILE=./data/cards.json
COLLECTION_NAME=failure_cards

# ================== Provider switch examples ==================
# [DeepSeek chat + OpenAI embedding]
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_CHAT_MODEL=deepseek-chat
#   LLM_API_KEY=sk-deepseek-xxx
#   EMBED_BASE_URL=https://api.openai.com/v1
#   EMBED_MODEL=text-embedding-3-small
#   EMBED_API_KEY=sk-openai-xxx
#
# [Qwen DashScope (OpenAI-compatible, chat + embedding)]
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_CHAT_MODEL=qwen-plus
#   LLM_API_KEY=sk-dashscope-xxx
#   EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   EMBED_MODEL=text-embedding-v3
#   EMBED_API_KEY=sk-dashscope-xxx
